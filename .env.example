# Postgres (host = 127.0.0.1 for local Bun runs; docker-compose overrides to "postgres" for worker container)
POSTGRES_USER=wetten
POSTGRES_PASSWORD=changeme
POSTGRES_DB=wetten
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

DATABASE_URL=postgres://wetten:changeme@127.0.0.1:5432/wetten

# Cloudflare Purge API (leave blank in Plan 1 — no-op)
CF_API_TOKEN=
CF_ZONE_ID=

# Logging
LOG_LEVEL=info

# Public base URL used by JSON-LD @id and CF purge URL construction
PUBLIC_BASE_URL=http://localhost:3000

# Cloudflare Tunnel (Zero Trust dashboard > Tunnels > token)
CF_TUNNEL_TOKEN=
